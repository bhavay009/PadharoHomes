# Copy to .env and fill in real values. .env is gitignored.

# Hosted Postgres (Neon/Supabase) connection string.
# Format (SQLAlchemy + psycopg v3):
#   postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
# Neon example:
#   postgresql+psycopg://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# App
APP_ENV=development

# JWT signing secret. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Cloudinary (photo uploads) — from your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional dashboard tuning (defaults shown).
# Assumed aggregator commission % a host avoids (for "commission saved").
# OTA_COMMISSION_PERCENT=15
# Rolling window (days) for the occupancy metric.
# OCCUPANCY_WINDOW_DAYS=30
# Payment gateway: mock | razorpay | stripe (only mock wired today).
# PAYMENT_GATEWAY=mock

# Email. provider: console (dev, logs/captures) | resend.
# With resend configured, OTPs + notifications send for real and OTP codes
# stop being returned in API responses.
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=

# Allowed frontend origins (comma-separated). Set to your Vercel URL in prod, e.g.
# CORS_ORIGINS=https://padharo-homes.vercel.app
CORS_ORIGINS=http://localhost:5173
